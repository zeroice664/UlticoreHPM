<?xml version="1.0" encoding="utf-8"?>
<!--
    ULTICORE HIGH PERFORMANCE MODE v2.0
    Main Activity Layout
    Dark-themed dashboard optimised for Honor 8X screen size
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111318"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ═══════════════════════════════════════
             HEADER - App title + device info
             ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/ivSpeedometer"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/speedometer_default"
                android:contentDescription="Performance indicator"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ULTICORE HPM"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvModelInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading device info..."
                    android:textColor="#888888"
                    android:textSize="11sp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- ═══════════════════════════════════════
             STATUS INDICATOR
             ═══════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvStatusLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="○ PERFORMANCE MODE: OFF"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#1A1D24"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

        <!-- ═══════════════════════════════════════
             MASTER TOGGLE CARD
             ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1E2330"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡  High Performance Mode"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enables all performance subsystems"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:paddingTop="2dp"/>
            </LinearLayout>

            <Switch
                android:id="@+id/switchMasterPerf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#00E676"
                android:trackTint="#1B5E20"/>
        </LinearLayout>

        <!-- ═══════════════════════════════════════
             SUB-OPTION: WiFi High Perf
             ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#161920"
            android:paddingStart="32dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📶  WiFi High Performance Lock"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Disables WiFi power saving — lower ping, stable throughput"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:paddingTop="2dp"/>
            </LinearLayout>

            <Switch
                android:id="@+id/switchWifiOpt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#40C4FF"
                android:trackTint="#0D47A1"/>
        </LinearLayout>

        <!-- ═══════════════════════════════════════
             SUB-OPTION: CPU Wake Lock
             ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#161920"
            android:paddingStart="32dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔋  CPU Wake Lock (Anti-Sleep)"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prevents CPU deep-sleep — eliminates wake-up latency"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:paddingTop="2dp"/>
            </LinearLayout>

            <Switch
                android:id="@+id/switchWakeLock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#FF6D00"
                android:trackTint="#E65100"/>
        </LinearLayout>

        <!-- ═══════════════════════════════════════
             SUB-OPTION: Network Boost
             ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#161920"
            android:paddingStart="32dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌐  Network Bandwidth Priority"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Binds process to best available network interface"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:paddingTop="2dp"/>
            </LinearLayout>

            <Switch
                android:id="@+id/switchNetBoost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#E040FB"
                android:trackTint="#4A148C"/>
        </LinearLayout>

        <!-- ═══════════════════════════════════════
             SUB-OPTION: Screen Always On
             ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#161920"
            android:paddingStart="32dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡  Keep Screen On"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Display stays on while app is open"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:paddingTop="2dp"/>
            </LinearLayout>

            <Switch
                android:id="@+id/switchScreenOn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#FFD740"
                android:trackTint="#F57F17"/>
        </LinearLayout>

        <!-- ═══════════════════════════════════════
             LIVE STATS DASHBOARD
             ═══════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1D24"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE STATS"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:paddingBottom="8dp"/>

            <TextView
                android:id="@+id/tvCpuFreq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CPU: Reading..."
                android:textColor="#EEEEEE"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:paddingBottom="4dp"/>

            <TextView
                android:id="@+id/tvBatteryLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Battery: —"
                android:textColor="#EEEEEE"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:paddingBottom="4dp"/>

            <TextView
                android:id="@+id/tvTemperature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Temp: —"
                android:textColor="#EEEEEE"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:paddingBottom="4dp"/>

            <TextView
                android:id="@+id/tvNetworkType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Network: —"
                android:textColor="#EEEEEE"
                android:textSize="13sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- ═══════════════════════════════════════
             NOTES FOOTER
             ═══════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ⓘ Grant 'Don\'t optimise' in battery settings for maximum effect. Service auto-restores on reboot."
            android:textColor="#555555"
            android:textSize="11sp"
            android:padding="12dp"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>
